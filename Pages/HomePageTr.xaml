<Page x:Class="WpfTali.HomePageTr"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfTali"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomePageTr">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="400"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.Background>
            <ImageBrush ImageSource="/images/homepage.png" Stretch="UniformToFill"/>
        </Grid.Background>
        <Button x:Name="Aboutus" Content="ABOUT US"  Width="100" Background="#f3cbdf" Click="AboutUsButton_Click" FontSize="15" Padding="10,5" Margin="289,11,19,385" Grid.Column="1" Grid.RowSpan="2"/>
        <Button x:Name="LogOut" Content="Log Out"  Width="100" Background="#f3cbdf"  FontFamily="/Fonts/#Alex Brush"
Click="LogOutButton_Click" FontSize="18" Height="30" Padding="10,5" Grid.Row="1" Margin="137,378,166,12" Grid.RowSpan="2"/>
        <TextBlock x:Name="lblWelcome" 
                   Text="Welcome to Fitali!" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center" 
                   FontSize="30" 
                   FontFamily="/Fonts/#Alex Brush"
                   Foreground="Black"
                   Grid.ColumnSpan="2"/>
        <StackPanel Grid.Column="1" Grid.Row="1" x:Name="workContacts" Orientation="Vertical" Margin="10,200,34,10" Grid.RowSpan="2" />

        <StackPanel Grid.Row="1" x:Name="spContacts" Orientation="Horizontal" Margin="10,0,10,22" HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Center" Width="300" Margin="0,20,0,0">
            <Button x:Name="btnChangePhoto" Click="btnChangePhoto_Click" Cursor="Hand" Margin="5,-14,5,24">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Button.Template>

                <Ellipse x:Name="profileEllipse" Width="90" Height="90" Stroke="#f3cbdf" StrokeThickness="2">
                    <Ellipse.Fill>
                        <ImageBrush Stretch="UniformToFill" ImageSource="/images/homepage.png"/>
                    </Ellipse.Fill>
                </Ellipse>
            </Button>
            <Button Background="#f3cbdf" FontSize="26" FontFamily="/Fonts/#Alex Brush" Content="More Information" Height="35" Width="220" Click="MoreInfo"/>
            <Button Background="#f3cbdf" FontSize="26" FontFamily="/Fonts/#Alex Brush" Content="Workouts" Height="35" Width="220" Margin="0,5,0,5" Click="Workouts"/>



        </StackPanel>
    </Grid>
</Page>