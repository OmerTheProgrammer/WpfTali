<Page x:Class="WpfTali.Pages.AboutUsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfTali.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1100"
      Title="AboutUsPage">
    <Grid Background="#FFF5F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="30,0,30,0">
            <Button x:Name="SignUpButton" 
                    Content="← Back" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Center"
                    Background="Transparent" 
                    Foreground="#D84B7E" 
                    BorderThickness="0"
                    FontWeight="SemiBold" 
                    FontSize="15" 
                    Cursor="Hand" 
                    Click="GoBack_Click"/>

            <TextBlock Text="Fitali" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="#D84B7E" 
                       FontFamily="Segoe UI"/>
        </Grid>

        <Grid Grid.Row="1" Margin="30,10,30,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Top" Margin="10,0,20,0">

                <StackPanel Orientation="Horizontal">
                    <Border Width="240" Height="450" Margin="8" CornerRadius="15" ClipToBounds="True">
                        <Image Source="pack://application:,,,/images/groupofwhite.jpg" Stretch="UniformToFill" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Orientation="Vertical">
                        <Border Width="250" Height="217" Margin="8" CornerRadius="15" ClipToBounds="True">
                            <Image Source="pack://application:,,,/images/pinkgirl.jpg" Stretch="UniformToFill" VerticalAlignment="Center"/>
                        </Border>

                        <Border Width="250" Height="217" Margin="8" CornerRadius="15" ClipToBounds="True">
                            <Image Source="pack://application:,,,/images/gym].jpg" Stretch="UniformToFill" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="Feel The Burn, Love The Glow" 
               HorizontalAlignment="Center" 
               Margin="0,20,0,0" 
               FontSize="18" 
               FontWeight="SemiBold" 
               FontStyle="Italic"
               Foreground="#D84B7E" 
               FontFamily="Segoe UI"/>
            </StackPanel>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Hidden" Margin="10,0,10,0">
                <StackPanel>

                    <Border Background="White" CornerRadius="15" Padding="25" Margin="0,0,0,15">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" Direction="270" ShadowDepth="3" Opacity="0.06"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="ABOUT US" FontSize="13" FontWeight="Bold" Foreground="#D84B7E" Margin="0,0,0,12"/>
                            <TextBlock Text="Welcome to Fitali, a modern fitness ecosystem designed to bridge the gap between trainers and trainees. Inspired by a passion for movement and community, Fitali simplifies your fitness journey with a seamless, digital environment accessible anytime, anywhere." 
                                       FontSize="15" Foreground="#4A4A4A" TextWrapping="Wrap" LineHeight="22"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FDE2E8" CornerRadius="15" Padding="25" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="OUR VISION" FontSize="13" FontWeight="Bold" Foreground="#D84B7E" Margin="0,0,0,12"/>
                            <TextBlock Text="To establish a premier, tech-driven fitness sanctuary that inspires a healthy, active, and balanced lifestyle." 
                                       FontSize="15" Foreground="#4A4A4A" TextWrapping="Wrap" LineHeight="22"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FDE2E8" CornerRadius="15" Padding="25" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="OUR MISSION" FontSize="13" FontWeight="Bold" Foreground="#D84B7E" Margin="0,0,0,12"/>
                            <TextBlock Text="To eliminate physical registration barriers, build efficient communication streams, and empower members to manage their training, memberships, and personal profiles effortlessly." 
                                       FontSize="15" Foreground="#4A4A4A" TextWrapping="Wrap" LineHeight="22"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="15" Padding="20" Margin="0,0,0,15">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" Direction="270" ShadowDepth="3" Opacity="0.06"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SAY HELLO" FontSize="12" FontWeight="Bold" Foreground="#A3A3A3" Margin="0,0,0,4"/>
                                <TextBlock Text="talimanager@gmail.com" FontSize="14" FontWeight="SemiBold" Foreground="#4A4A4A"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="CALL US" FontSize="12" FontWeight="Bold" Foreground="#A3A3A3" Margin="0,0,0,4"/>
                                <TextBlock Text="054-3115841" FontSize="14" FontWeight="SemiBold" Foreground="#4A4A4A"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>

</Page>