<Page x:Class="WpfTali.Pages.WorkoutsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="WorkoutsPage" Background="#FFE4E1" FlowDirection="RightToLeft">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Workouts Hours" FontSize="24" FontWeight="Bold" Foreground="#1E1E24" Margin="0,0,0,15"/>

            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Button x:Name="PrevMonthButton" Content="→" Click="PrevMonthButton_Click" Background="Transparent" BorderThickness="0" FontSize="20" FontWeight="Bold" Foreground="#FF1493" Cursor="Hand" Padding="10,0"/>
                    <TextBlock x:Name="MonthYearTextBlock" Text="מאי 2026" FontSize="18" FontWeight="Bold" Foreground="#333" Width="120" TextAlignment="Center" VerticalAlignment="Center"/>
                    <Button x:Name="NextMonthButton" Content="←" Click="NextMonthButton_Click" Background="Transparent" BorderThickness="0" FontSize="20" FontWeight="Bold" Foreground="#FF1493" Cursor="Hand" Padding="10,0"/>
                </StackPanel>

                <ListBox x:Name="DaysListBox" Grid.Row="1" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled" SelectionChanged="DaysListBox_SelectionChanged" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="DayBorder" BorderThickness="0" CornerRadius="10" Padding="10,8" Margin="4" Background="White" Width="65" Height="60" Cursor="Hand">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DayOfWeekHebrew}" FontSize="11" HorizontalAlignment="Center" Foreground="#666"/>
                                    <TextBlock Text="{Binding DayNumber}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#333" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="DayBorder" Property="Background" Value="#FF1493"/>
                                    <Setter TargetName="DayBorder" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.3" Color="#FF1493"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <ListView x:Name="WorkoutsListView" Grid.Row="2" SelectionChanged="WorkoutsListView_SelectionChanged" Background="Transparent" BorderThickness="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,6"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="WorkoutCard" Background="White" CornerRadius="14" Padding="15" BorderThickness="1" BorderBrush="#EAEAEA">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.04"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding TimeStr}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="#222"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                    <TextBlock Text="{Binding WorkoutName}" FontSize="16" FontWeight="Bold" Foreground="#1E1E24"/>
                                    <TextBlock Text="{Binding TrainerName}" FontSize="13" Foreground="#666" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#888" Margin="0,2,0,0"/>
                                </StackPanel>

                                <Border Grid.Column="2" x:Name="StatusBadge" CornerRadius="12" Padding="12,6" VerticalAlignment="Center" Background="#F5F5F5">
                                    <TextBlock x:Name="StatusText" Text="פנוי" Foreground="#444" FontSize="12" FontWeight="Medium"/>
                                </Border>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsUserRegistered}" Value="True">
                                <Setter TargetName="WorkoutCard" Property="Background" Value="#FFF0F5"/>
                                <Setter TargetName="WorkoutCard" Property="BorderBrush" Value="#FFB6C1"/>
                                <Setter TargetName="StatusBadge" Property="Background" Value="#FF1493"/>
                                <Setter TargetName="StatusText" Property="Text" Value="רשום"/>
                                <Setter TargetName="StatusText" Property="Foreground" Value="White"/>
                                <Setter TargetName="StatusText" Property="FontWeight" Value="Bold"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Border Grid.Column="1" x:Name="DetailsPanel" Visibility="Collapsed" Background="White" CornerRadius="16" BorderThickness="1" BorderBrush="#F0F0F0" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock x:Name="DetailWorkoutName" Text="שם האימון" FontSize="20" FontWeight="Bold" Foreground="#1E1E24" HorizontalAlignment="Center"/>
                    <Separator Margin="0,10,0,0" Background="#FFE4E1"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,15">
                    <TextBlock x:Name="DetailTrainer" Text="מאמן/ת: " FontSize="14" Margin="0,5" Foreground="#333"/>
                    <TextBlock x:Name="DetailDate" Text="תאריך: " FontSize="14" Margin="0,5" Foreground="#333"/>
                    <TextBlock x:Name="DetailTime" Text="שעה: " FontSize="14" Margin="0,5" Foreground="#333"/>
                    <TextBlock x:Name="DetailStatus" Text="סטטוס: " FontSize="14" Margin="0,5" Foreground="#333"/>
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="מתאמנים רשומים באימון:" FontWeight="Bold" FontSize="13" Margin="0,0,0,8" Foreground="#555"/>
                    <ListView x:Name="RegisteredTraineesListView" Grid.Row="1" Background="#FAFAFA" BorderBrush="#EAEAEA">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" >
                                    <TextBlock Text="{Binding first_name}" FontWeight="Medium" Foreground="#333"/>
                                    <TextBlock Text=" "/>
                                    <TextBlock Text="{Binding last_name}" Foreground="#333"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <Button Grid.Row="3" x:Name="ActionButton" Click="ActionButton_Click" Height="45" Foreground="White" FontWeight="Bold" FontSize="16" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>