<Page x:Class="WpfTali.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfTali"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="WelcomePage">
    <Button x:Name="welcomeButton"  Click="welcometo" Background="Transparent"
            BorderBrush="Transparent"
            Padding="0"
            Cursor="Hand">
        <MediaElement x:Name="BackgroundVideo" 
       LoadedBehavior="Manual"
       UnloadedBehavior="Stop"
       Stretch="UniformToFill"
       IsMuted="False"
       MediaEnded="BackgroundVideo_MediaEnded" />
    </Button>
</Page>