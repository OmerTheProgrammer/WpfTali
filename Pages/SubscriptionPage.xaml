<Page x:Class="WpfTali.Pages.SubscriptionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SubscriptionPage">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/images/moreinformation.jpg" Stretch="UniformToFill"/>
        </Grid.Background>

        <ListView x:Name="SubscriptionsList" BorderThickness="0" Background="Transparent" SelectionChanged="SubscriptionsList_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="SubBorder" Width="250" Height="150" Margin="10" Padding="20" 
                            CornerRadius="15" BorderBrush="Black" BorderThickness="1"
                            Background="{Binding BackgroundColor}">
                        <StackPanel>
                            <TextBlock Text="{Binding name_of_sub}" FontSize="32" FontWeight="Bold" Foreground="Black" FontFamily="/Fonts/#Alex Brush" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding price_display}" FontSize="18" Foreground="Black" Margin="0,10" FontFamily="/Fonts/#Alex Brush" HorizontalAlignment="Center"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Purchase" Background="White" Foreground="Black" Width="80" Margin="5" FontFamily="/Fonts/#Alex Brush" Click="Purchase_Click"/>
                                <Button Content="Cancel" Background="Transparent" Foreground="Black" BorderThickness="0" FontFamily="/Fonts/#Alex Brush" Width="70" Margin="5" Click="CancelSub_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border x:Name="PaymentPanel" Visibility="Collapsed" Background="White" BorderBrush="Black" BorderThickness="2" 
                CornerRadius="20" Width="300" Height="450" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Payment Details" FontSize="24" FontWeight="Bold" FontFamily="/Fonts/#Alex Brush" Foreground="Black" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <TextBlock Text="First Name:" Foreground="Black"/>
                <TextBox x:Name="TxtFirstName" Margin="0,0,0,10" Background="White" BorderBrush="Pink"/>

                <TextBlock Text="Username:" Foreground="Black"/>
                <TextBox x:Name="TxtUsername" Margin="0,0,0,10" Background="White" BorderBrush="Pink"/>

                <TextBlock Text="Phone Number:" Foreground="Black"/>
                <TextBox x:Name="TxtPhone" Margin="0,0,0,10" Background="White" BorderBrush="Pink"/>

                <TextBlock Text="Email Address:" Foreground="Black"/>
                <TextBox x:Name="TxtEmail" Margin="0,0,0,10" Background="White" BorderBrush="Pink"/>

                <TextBlock Text="Card Number:" Foreground="Black"/>
                <TextBox Margin="0,0,0,10" Background="White" BorderBrush="Pink"/>

                <StackPanel Orientation="Horizontal">
                    <StackPanel Width="120" Margin="0,0,10,0">
                        <TextBlock Text="Expiry Date:" Foreground="Black"/>
                        <TextBox Background="White" BorderBrush="Pink"/>
                    </StackPanel>
                    <StackPanel Width="120">
                        <TextBlock Text="CVV:" Foreground="Black"/>
                        <TextBox Background="White" BorderBrush="Pink"/>
                    </StackPanel>
                </StackPanel>

                <Button Content="Confirm Purchase" FontFamily="/Fonts/#Alex Brush" Background="Pink" Foreground="Black" FontWeight="Bold" Margin="0,30,0,0" Padding="10" Click="ConfirmPurchase_Click"/>
                <Button Content="Back" FontFamily="/Fonts/#Alex Brush" Background="Transparent" Foreground="Black" BorderThickness="0" Click="Back_Click"/>
            </StackPanel>
        </Border>

        <Button Content="Back" Click="back_Click_1" Background="Pink" FontFamily="/Fonts/#Alex Brush" Height="30" Width="50" Margin="600,225,-10,195"/>
    </Grid>
</Page>