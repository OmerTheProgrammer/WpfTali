<Page x:Class="WpfTali.HomePageTe"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfTali"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomePageTe"  JournalEntry.KeepAlive="True">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="400"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.Background>
            <ImageBrush ImageSource="/images/homepage.png" Stretch="UniformToFill"/>
        </Grid.Background>
        <Button x:Name="Aboutus" Content="ABOUT US"  Width="100" Background="#f3cbdf" Click="AboutUsButton_Click" FontSize="15" Padding="10,5" Margin="249,138,50,234" Grid.Row="1" Grid.Column="1"/>
        <Button x:Name="LogOut" Content="Log Out" Height="30" Background="#f3cbdf"  FontFamily="/Fonts/#Alex Brush"
Click="LogOutButton_Click" FontSize="18"  Width="100" Padding="10,5" Grid.Row="1" Margin="151,373,152,10" Grid.RowSpan="2"/>
        <TextBlock x:Name="lblWelcome" 
                   Text="Welcome to Fitali!" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center" 
                   FontSize="30" 
                   FontFamily="/Fonts/#Alex Brush"
                   Foreground="Black"/>
        <StackPanel Grid.Row="1" x:Name="spContacts" Orientation="Horizontal" />
        <Border Grid.Column="1" Grid.Row="1" Height="100" Width="100" HorizontalAlignment="Left" Margin="75,0,0,300" VerticalAlignment="Bottom">
            <Button x:Name="btnChangePhoto" Click="btnChangePhoto_Click" Cursor="Hand" Margin="5,-14,5,24">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Button.Template>

                <Ellipse x:Name="profileEllipse" Width="90" Height="90" Stroke="#f3cbdf" StrokeThickness="2">
                    <Ellipse.Fill>
                        <ImageBrush Stretch="UniformToFill" ImageSource="/images/homepage.png"/>
                    </Ellipse.Fill>
                </Ellipse>
            </Button>
        </Border>

        <StackPanel Height="100" Grid.Column="1" HorizontalAlignment="Left" Margin="233,10,0,290" Grid.Row="1">
            <TextBlock Text="Working Since:"  FontFamily="/Fonts/#Alex Brush" FontSize="24" Foreground="Black"/>
            <TextBlock x:Name="lblJoiningDate" FontSize="18" FontWeight="Bold" Foreground="White" Height="30" FontFamily="/Fonts/#Alex Brush"/>
        </StackPanel>
        <Button Grid.Row="1" Grid.Column="1" Background="#f3cbdf" FontSize="30" FontFamily="/Fonts/#Alex Brush" Content="Workouts" Height="50" Width="150" HorizontalAlignment="Left" Margin="50,95,0,255" Click="Workouts"/>
        <Button Grid.Row="1" Grid.Column="1" Background="#f3cbdf" FontSize="30" FontFamily="/Fonts/#Alex Brush" Content="Subscription" Height="50" Width="150" HorizontalAlignment="Left" Click="Subscription" Margin="50,150,0,200"/>

        <ScrollViewer Grid.Column="1" 
                      Grid.Row="1" 
                      Grid.RowSpan="2" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="22,210,22,0">
            <StackPanel x:Name="traineeWorkoutsPanel" Orientation="Vertical" />
        </ScrollViewer>
    </Grid>
</Page>