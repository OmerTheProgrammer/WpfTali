<Page x:Class="WpfTali.Pages.ManagePeoplePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ManagePeoplePage" Background="#FFE4E1" FlowDirection="RightToLeft">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.8*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                <Button x:Name="BtnBack" Width="40" Height="40" Content="➜" FontSize="20" FontWeight="Bold"
                        Background="#FF1493" Foreground="White" Cursor="Hand" Click="BtnBack_Click" Margin="0,0,15,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="20"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <TextBlock Text="ניהול אנשים במערכת" FontSize="22" FontWeight="Bold" Foreground="#1E1E24" VerticalAlignment="Center"/>
            </StackPanel>

            <DataGrid x:Name="PeopleDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                      SelectionChanged="PeopleDataGrid_SelectionChanged" Background="White" RowBackground="#FAFAFA">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                    <DataGridTextColumn Header="ת.ז" Binding="{Binding Num_id}" Width="80"/>
                    <DataGridTextColumn Header="שם משתמש" Binding="{Binding User_name}" Width="90"/>
                    <DataGridTextColumn Header="שם פרטי" Binding="{Binding First_name}" Width="*"/>
                    <DataGridTextColumn Header="שם משפחה" Binding="{Binding Last_name}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="5,0,5,0">

                <Ellipse Width="110" Height="110" HorizontalAlignment="Center" Margin="0,0,0,15" Stroke="White" StrokeThickness="3">
                    <!--<Ellipse.Fill>
                        <ImageBrush x:Name="ImgProfile" ImageSource="/images/" Stretch="UniformToFill"/>
                    </Ellipse.Fill>-->
                </Ellipse>

                <Border Background="White" CornerRadius="20" Padding="20" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="My Profile / עריכה" FontSize="18" FontWeight="Bold" Foreground="#C71585" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Margin="5,0,0,10">
                                <TextBlock Text="FIRST NAME" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                                <TextBox x:Name="TxtFirstName" Height="30" Background="#F9F9F9" BorderThickness="0" Padding="5,2"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Margin="0,0,5,10">
                                <TextBlock Text="LAST NAME" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                                <TextBox x:Name="TxtLastName" Height="30" Background="#F9F9F9" BorderThickness="0" Padding="5,2"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="EMAIL ADDRESS" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                        <TextBox x:Name="TxtEmail" Height="30" Background="#F9F9F9" BorderThickness="0" Margin="0,2,0,10" Padding="5,2"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Margin="5,0,0,10">
                                <TextBlock Text="PHONE" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                                <TextBox x:Name="TxtPhone" Height="30" Background="#F9F9F9" BorderThickness="0" Padding="5,2"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Margin="0,0,5,10">
                                <TextBlock Text="PASSWORD" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                                <TextBox x:Name="TxtPassword" Height="30" Background="#F9F9F9" BorderThickness="0" Padding="5,2"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Margin="5,0,0,10">
                                <TextBlock Text="ID NUMBER" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                                <TextBox x:Name="TxtNumId" Height="30" Background="#F9F9F9" BorderThickness="0" Padding="5,2"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Margin="0,0,5,10">
                                <TextBlock Text="USER NAME" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                                <TextBox x:Name="TxtUserName" Height="30" Background="#F9F9F9" BorderThickness="0" Padding="5,2"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Margin="5,0,0,10">
                                <TextBlock Text="BIRTHDAY" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                                <DatePicker x:Name="DpBornDate" Height="30" BorderThickness="0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Margin="0,0,5,10">
                                <TextBlock Text="GENDER (1=M, 2=F)" FontSize="10" Foreground="Gray" FontWeight="Bold"/>
                                <TextBox x:Name="TxtGenderId" Height="30" Background="#F9F9F9" BorderThickness="0" Padding="5,2"/>
                            </StackPanel>
                        </Grid>

                        <UniformGrid Columns="3" Margin="0,15,0,0" Height="35">
                            <Button Content="הוסף" Click="BtnAdd_Click" Background="#FF1493" Foreground="White" FontWeight="Bold" Margin="2"/>
                            <Button Content="עדכן" Click="BtnUpdate_Click" Background="#FF69B4" Foreground="White" FontWeight="Bold" Margin="2"/>
                            <Button Content="מחק" Click="BtnDelete_Click" Background="#D2143A" Foreground="White" FontWeight="Bold" Margin="2"/>
                        </UniformGrid>
                        <Button Content="ניקוי שדות" Click="BtnClear_Click" Background="#808080" Foreground="White" Margin="2,8,2,0" Height="28"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>