<Page x:Class="WpfTali.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1000"
      Title="RegistrationPage">

    <Page.Resources>
        <Style x:Key="ModernInputStyle" TargetType="Control">
            <Setter Property="BorderThickness" Value="0,0,0,1.5"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0,2"/>
            <Setter Property="VerticalContentAlignment" Value="Bottom"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Page.Resources>

    <Grid Background="#F8F2F4">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,30,50,0">
            <Button x:Name="Aboutus" Content="ABOUT US" Foreground="#be5e84" Background="White" Click="AboutUsButton_Click" FontSize="15" Padding="10,5"/>
        </StackPanel>

        <Border Background="White" CornerRadius="10" MaxWidth="900" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.1" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="45,20">
                    <TextBlock Text="Sign up" FontSize="50" Foreground="#1a1a2e" Margin="0,0,0,20"/>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Private name" FontSize="13"/>
                            <TextBox x:Name="pName" Style="{StaticResource ModernInputStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Family name" FontSize="13" />
                            <TextBox x:Name="lName" Style="{StaticResource ModernInputStyle}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Email Address" FontSize="13" Margin="0,15,0,0"/>
                    <TextBox x:Name="Email" Style="{StaticResource ModernInputStyle}" Margin="0,0,0,15"/>

                    <TextBlock Text="User name" FontSize="13"/>
                    <TextBox x:Name="UserName" Style="{StaticResource ModernInputStyle}" Width="150" HorizontalAlignment="Left" Margin="0,0,0,15"/>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Password" FontSize="13"/>
                            <PasswordBox x:Name="Pass" Style="{StaticResource ModernInputStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Telephone" FontSize="13"/>
                            <TextBox x:Name="telephone" Style="{StaticResource ModernInputStyle}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Born date" FontSize="13"/>
                            <DatePicker x:Name="bornDate" BorderThickness="0,0,0,1.5" Background="Transparent"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Id number" FontSize="13"/>
                            <TextBox x:Name="idNum" Style="{StaticResource ModernInputStyle}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <StackPanel Width="150">
                            <TextBlock Text="Gender" FontSize="13" HorizontalAlignment="Center"/>
                            <ComboBox x:Name="GenderComboBox" Style="{StaticResource ModernInputStyle}" Width="120" HorizontalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Width="150">
                            <TextBlock Text="Kind of user" FontSize="13" HorizontalAlignment="Center"/>
                            <ComboBox x:Name="UserTypeComboBox" Style="{StaticResource ModernInputStyle}" Width="120" HorizontalAlignment="Center" FontSize="12">
                                <ComboBoxItem Content="Trainee"/>
                                <ComboBoxItem Content="Trainer"/>
                                <ComboBoxItem Content="Manager"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <Button Content="Create Account" Click="SignUpButton_Click" FontSize="18" Background="#f3cbdf" Foreground="White" Height="40" Margin="0,20,0,10"/>
                    <Button x:Name="LogIn" Content="Already have an account? Log In" FontSize="14" Background="Transparent" BorderThickness="0" Foreground="#be5e84" Click="LogInButton_Click"/>
                </StackPanel>

                <Grid Grid.Column="1" Margin="5">
                    <Image Source="/images/signup.png" Stretch="UniformToFill">
                        <Image.Clip>
                            <RectangleGeometry Rect="0,0,1000,1000" RadiusX="10" RadiusY="10"/>
                        </Image.Clip>
                    </Image>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>