<Page x:Class="WpfTali.Pages.ManageWorkoutsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ManageWorkoutsPage" Background="#FFE4E1" FlowDirection="RightToLeft">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                <Button x:Name="BtnBack" Width="40" Height="40" Content="➜" FontSize="20" FontWeight="Bold"
                        Background="#FF1493" Foreground="White" Cursor="Hand" Click="BtnBack_Click" Margin="0,0,15,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="20"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock Text="ניהול לוח אימונים (מנהל)" FontSize="22" FontWeight="Bold" Foreground="#1E1E24" VerticalAlignment="Center"/>
            </StackPanel>

            <DataGrid x:Name="WorkoutsDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionChanged="WorkoutsDataGrid_SelectionChanged" Background="White" RowBackground="#FAFAFA">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="קוד אימון" Binding="{Binding Id}" Width="70"/>
                    <DataGridTextColumn Header="תאריך" Binding="{Binding Workout_date, StringFormat=\{0:dd/MM/yyyy\}}" Width="110"/>
                    <DataGridTextColumn Header="שעה" Binding="{Binding Workout_date, StringFormat=\{0:HH:mm\}}" Width="80"/>
                    <DataGridTextColumn Header="סוג אימון (קוד)" Binding="{Binding Id_kindOf_workouts.Id}" Width="100"/>
                    <DataGridTextColumn Header="מאמן (קוד)" Binding="{Binding Id_trainer.Id}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="15" VerticalAlignment="Top">
            <StackPanel >
                <TextBlock Text="פרטי אימון" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="תאריך אימון:"/>
                <DatePicker x:Name="DpDate" Height="30"/>

                <TextBlock Text="שעה (לדוגמה 15:30):"/>
                <TextBox x:Name="TxtTime" Height="30" Background="#F9F9F9" BorderThickness="0" Padding="5,2"/>

                <TextBlock Text="קוד סוג אימון (ID):"/>
                <TextBox x:Name="TxtKindId" Height="30" Background="#F9F9F9" BorderThickness="0" Padding="5,2"/>

                <TextBlock Text="קוד מאמן (ID):"/>
                <TextBox x:Name="TxtTrainerId" Height="30" Background="#F9F9F9" BorderThickness="0" Padding="5,2"/>

                <UniformGrid Columns="3" Margin="0,20,0,0" Height="40">
                    <Button Content="הוסף" Click="BtnAdd_Click" Background="#FF1493" Foreground="White" FontWeight="Bold" Margin="2"/>
                    <Button Content="עדכן" Click="BtnUpdate_Click" Background="#FF69B4" Foreground="White" FontWeight="Bold" Margin="2"/>
                    <Button Content="מחק" Click="BtnDelete_Click" Background="#D2143A" Foreground="White" FontWeight="Bold" Margin="2"/>
                </UniformGrid>

                <Button Content="ניקוי שדות" Click="BtnClear_Click" Background="Gray" Foreground="White" Margin="2,8,2,0" Height="28"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>