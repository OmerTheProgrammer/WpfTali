<Page x:Class="WpfTali.Pages.PageMoreInformation"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfTali.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageMoreInformation">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/images/moreinformation.jpg" Stretch="UniformToFill"/>
        </Grid.Background>
        <StackPanel x:Name="moreContacts" Orientation="Vertical" Height="300" 
                        Width="300" />
        <Button Content="Back" FontSize="20" Click="Back_Click" Background="Pink"  FontFamily="/Fonts/#Alex Brush" Height="40" Width="70" Margin="384,400,346,10"></Button>
    </Grid>
</Page>
