<UserControl x:Class="WpfTali.UserControls.UserControlTraineeW"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfTali.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="400" FlowDirection="RightToLeft">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="האימונים הקרובים שלי"   FontSize="18"   FontWeight="Bold"   Foreground="#1E1E24"   Margin="5,0,5,10"/>

        <ListBox Grid.Row="1"  x:Name="MyWorkoutsListBox"   Background="Transparent"   BorderThickness="0"  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,5"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="White"  CornerRadius="12"  Padding="15"   BorderThickness="1"  BorderBrush="#FFE4E1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.05"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding TimeStr}"  FontSize="16"   FontWeight="Bold"  Foreground="#222222"   VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding WorkoutName}"  FontSize="15"   FontWeight="Bold"   Foreground="#1E1E24"/>
                                <TextBlock Text="{Binding TrainerName}"  FontSize="13"  Foreground="#666666"  Margin="0,3,0,0"/>
                                <TextBlock Text="{Binding RawWorkout.Workout_date, StringFormat=\{0:dd/MM/yyyy\}}"  FontSize="12" Foreground="#FF1493"  FontWeight="SemiBold"  Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>